{
  "name": "marketoracle-ai",
  "private": true,
  "packageManager": "npm@10.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:backend": "npm --workspace backend run dev",
    "dev:frontend": "npm --workspace frontend run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "format": "prettier . --write",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "prisma:generate": "npm --workspace backend run prisma:generate",
    "prisma:migrate:dev": "npm --workspace backend run prisma:migrate:dev",
    "prisma:migrate:deploy": "npm --workspace backend run prisma:migrate:deploy"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.0.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.0.0",
    "turbo": "^2.0.0"
  }
}